<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="actuator" params="pre r l colour">
        <link name="${pre}_link">
            <visual>
                <geometry>
                    <cylinder radius="${r}" length="${l}" />
                </geometry>
                <material name="${colour}" />
                <origin xyz="0 0 ${l/2}" rpy="0 0 0" />
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${r}" length="${l}" />
                </geometry>
                <origin xyz="0 0 ${l/2}" rpy="0 0 0" />
            </collision>
            <xacro:cylinder_inertia m="0.3" r="${r}" l="${l}" o_xyz="0 0 0" o_rpy="0 0 0" />
        </link>
    </xacro:macro>

    <link name="base_footprint_actuator">
    </link>



    <link name="base_actuator_link">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.02" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="orange" />
        </visual>
        <collision>
            <geometry>
                <box size="0.1 0.1 0.02" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="4.0" x="0.1" y="0.1" z="0.02" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>



    <joint name="base_base" type="fixed">
            <parent link="base_footprint_actuator" />
            <child link="base_actuator_link" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </joint>
    <xacro:actuator pre="forearm" r="0.02" l="0.3" colour="yellow" />



    <joint name="base_forearm" type="revolute">
    <limit effort="10" velocity="100" lower="0" upper="1.57" />
    <dynamic friction="0.3" damping="0.3" />
        <parent link="base_actuator_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <xacro:actuator pre="hand" r="0.02" l="0.3" colour="orange" />

    <joint name="forearm_hand" type="revolute">
        <limit effort="10" velocity="100" lower="0" upper="1.57" />
        <dynamic friction="0.3" damping="0.3" />
        <parent link="forearm_link" />
        <child link="hand_link" />
        <origin xyz="0 0 0.3" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>
</robot>